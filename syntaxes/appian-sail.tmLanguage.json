{
    "name": "Appian",
    "scopeName": "source.devtools-appian",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#prefixed-functions"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#constants"
        },
        {
            "include": "#variables"
        },
        {
            "include": "#fn-invocations"
        },
        {
            "include": "#type-references"
        },
        {
            "include": "#control-keywords"
        },
        {
            "include": "#standard-functions"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#punctuation"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.block",
                    "begin": "/\\*",
                    "end": "\\*/"
                },
                {
                    "name": "comment.line.double-slash",
                    "match": "//.*$"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.single",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric",
                    "match": "\\b\\d+\\.\\d+\\b"
                },
                {
                    "name": "constant.numeric",
                    "match": "\\b\\d+\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language",
                    "match": "\\b(true|false)\\b"
                },
                {
                    "name": "constant.language",
                    "match": "\\b(null)\\b"
                },
                {
                    "name": "constant.language",
                    "match": "\\b(ARRAY_STYLE_STANDARD|BOOLEAN|DATE|DATETIME|DECIMAL|FOLDER|INTEGER|TEXT|TIME|TIMESTAMP|VARIANT)\\b"
                }
            ]
        },
        "variables": {
            "patterns": [
                {
                    "name": "variable.other",
                    "match": "\\blocal!\\w+"
                },
                {
                    "name": "variable.other",
                    "match": "\\bri!\\w+"
                },
                {
                    "name": "variable.other",
                    "match": "\\brv!\\w+"
                },
                {
                    "name": "variable.other",
                    "match": "\\bpv!\\w+"
                },
                {
                    "name": "variable.other",
                    "match": "\\bac!\\w+"
                },
                {
                    "name": "variable.other",
                    "match": "\\bsave!\\w+"
                },
                {
                    "name": "variable.other",
                    "match": "\\brule!\\w+"
                },
                {
                    "name": "variable.other",
                    "match": "\\bcons!\\w+"
                },
                {
                    "name": "variable.other",
                    "match": "\\btype!\\w+"
                },
                {
                    "name": "variable.other",
                    "match": "\\bfv!\\w+"
                }
            ]
        },
        "fn-invocations": {
            "patterns": [
                {
                    "name": "support.function",
                    "match": "\\bfn!\\w+"
                }
            ]
        },
        "type-references": {
            "patterns": [
                {
                    "name": "support.type",
                    "match": "'type!(\\w+)'"
                },
                {
                    "name": "entity.name.type",
                    "match": "\\brecordType!(\\w+)\\.(fields|relationships)\\.(\\w+)"
                },
                {
                    "name": "entity.name.type",
                    "match": "\\brecordType!(\\w+)"
                }
            ]
        },
        "prefixed-functions": {
            "patterns": [
                {
                    "name": "support.function",
                    "match": "\\b(a![a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
                },
                {
                    "name": "support.function",
                    "match": "\\b(a![a-zA-Z_][a-zA-Z0-9_]*)"
                }
            ]
        },
        "control-keywords": {
            "patterns": [
                {
                    "name": "keyword.control",
                    "match": "\\b(if|choose|and|or|not)\\b"
                },
                {
                    "name": "keyword.other",
                    "match": "\\b(load|with|a!localVariables|a!save|bind)\\b"
                }
            ]
        },
        "standard-functions": {
            "patterns": [
                {
                    "name": "support.function",
                    "match": "\\b(append|index|insert|joinarray|ldrop|length|rdrop|remove|reverse|updatearray|where|wherecontains|displayvalue|externalize|internalize|toboolean|tocommunity|todate|todatetime|todecimal|todocument|toemailaddress|toemailrecipient|tofolder|tointeger|tointervalds|toknowledgecenter|tostring|totime|touniformstring|touser|togroup|bin2dec|bin2hex|bin2oct|dec2bin|dec2hex|dec2oct|hex2bin|hex2dec|hex2oct|oct2bin|oct2dec|oct2hex|abs|avg|ceiling|char|clean|code|concat|choose|contains|count|date|datetime|datevalue|day|dayofyear|days360|daysinmonth|edate|eomonth|even|exact|exp|fact|find|fixed|floor|gmt|hour|int|intervalds|isleapyear|isnull|lastndays|left|len|ln|local|log|lower|max|mid|milli|min|minute|mod|month|networkdays|now|odd|power|proper|rand|repeat|replace|right|round|rounddown|roundup|search|second|sin|cos|tan|asin|acos|atan|sqrt|substitute|sum|text|time|timevalue|timezone|timezoneid|today|trim|typeof|upper|value|weekday|weeknum|with|workday|year|yearfrac|apply|merge|reject|reduce|rule|load|bind|save|property|enumerate|cast|difference|intersection|union|distinct|sort|userdatetime|toencodedpath|torecord|urlforrecord|userlocale|loggedInUser|loggedinuser|numontask|webservicequery|webservicewrite|topeople|isusermemberofgroup|getprocessid|getdistinctusers|reconciletimezones|calendartoday|usertimezone|todiscussionthread|toapplicationuser)(?=\\s*\\()"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator",
                    "match": "<>|>=|<=|>|<|="
                },
                {
                    "name": "keyword.operator",
                    "match": "\\+|-|\\*|/"
                },
                {
                    "name": "keyword.operator",
                    "match": "&"
                },
                {
                    "name": "keyword.operator",
                    "match": ":"
                }
            ]
        },
        "punctuation": {
            "patterns": [
                {
                    "name": "punctuation.separator",
                    "match": ","
                },
                {
                    "name": "punctuation.definition.parameters.begin",
                    "match": "\\("
                },
                {
                    "name": "punctuation.definition.parameters.end",
                    "match": "\\)"
                },
                {
                    "name": "punctuation.definition.begin",
                    "match": "\\["
                },
                {
                    "name": "punctuation.definition.end",
                    "match": "\\]"
                },
                {
                    "name": "punctuation.section.block.begin",
                    "match": "\\{"
                },
                {
                    "name": "punctuation.section.block.end",
                    "match": "\\}"
                }
            ]
        }
    }
}
